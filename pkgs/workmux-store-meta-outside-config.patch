+/// Path to workmux's metadata file alongside `.git/config`.
+///
+/// workmux stores `branch.<n>.workmux-base` and `workmux.worktree.<n>.<k>` in
+/// `$GIT_COMMON_DIR/workmux-config` rather than `.git/config` so sandboxes
+/// that deny writes to `.git/config` (Claude Code's built-in sandbox among
+/// them) don't block `workmux add`.
+pub fn get_workmux_config_path_in(workdir: Option<&Path>) -> Result<PathBuf> {
+    Ok(get_git_common_dir_in(workdir)?.join("workmux-config"))
+}
